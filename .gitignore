# Logs
./logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
.coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Packaged VSCode extension bundles
*.vsix

# Built dictionary database (regenerated by `vp run build:data`, delivered via download)
/assets/jisho.db
/assets/jisho.db-wal
/assets/jisho.db-shm
/assets/jisho.db.version
# Built names database (regenerated by `vp run build:data:names`, delivered via download)
/assets/jisho-names.db
/assets/jisho-names.db-wal
/assets/jisho-names.db-shm
/assets/jisho-names.db.version

# Typescript
*.tsbuildinfo

# Jest
/coverage
packages/**/coverage

# Yarn
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Storybook
storybook-static/

# dotenv environment variables file
.env
.env.*

.turbo
.next/
.cache/
**/dist/
coverage/
**/public/workbox-*.js*
**/public/sw.js*
**/public/worker-*.js*
results
yarn-error.log
.idea
schema.json

# Ignore user-specific VSCode state, but keep shared extension-dev config (F5 launch + build tasks)
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

cypress/e2e/build

.DS_Store
.vercel/*
!.vercel/package.json

# Claude Code local agent state
.claude/

# CPU profiles emitted by scripts/profile.mjs
profiles/
*.cpuprofile

# E2E: the VS Code build @vscode/test-electron downloads (~224MB) and Playwright's run artifacts
.vscode-test/
test-results/
playwright-report/

# Temp vsix extraction for packaging verification
.vsix-verify.tmp/
/assets/jisho-full.db.gz
/assets/jisho-full.db.gz.sha256
/assets/jisho-full.db.version
/assets/jisho-names.db.gz
/assets/jisho-names.db.gz.sha256
/assets/jisho-names.db.gz.version

# Per-platform packages built by scripts/package-platforms.ts
dist-vsix/
.platform-pkgs.tmp/

# Vitest browser mode: failure screenshots + attachments, regenerated per run.
# (Committed visual-regression baselines, when we add them, will live elsewhere and be tracked.)
.vitest-attachments/
**/__screenshots__/
# Output of the *.preview.browser.spec.tsx visual benches — regenerated on every run.
**/*-preview.png

# Benchmark baselines are machine-specific: comparing your numbers to a teammate's (or CI's)
# hardware measures the hardware, not the change. Generate locally with `vp run bench:save`.
bench/baseline.json
