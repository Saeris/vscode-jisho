{
  "name": "vscode-jisho",
  "displayName": "Jisho — Japanese Dictionary",
  "version": "0.0.0",
  "description": "An offline Japanese dictionary in your sidebar: vocabulary and kanji search powered by JMdict, Kanjidic, and friends.",
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "japanese",
    "dictionary",
    "jisho",
    "jmdict",
    "kanji"
  ],
  "homepage": "https://github.com/Saeris/vscode-jisho#readme",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saeris/vscode-jisho.git"
  },
  "publisher": "saeris",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "ci": "vp check && vp test",
    "build": "vp pack && vp build && vp exec vsce package --no-yarn",
    "build:platforms": "vp pack && vp build && vp exec node scripts/package-platforms.ts",
    "build:data": "vp exec node scripts/build-data.ts",
    "build:strokes": "vp exec node scripts/build-strokes.ts",
    "build:data:full": "vp exec node scripts/build-data.ts --full",
    "build:data:names": "vp exec node scripts/build-data.ts --names",
    "bench": "vp test bench --run --project bench",
    "bench:save": "vp test bench --run --project bench --outputJson bench/baseline.json",
    "bench:compare": "vp test bench --run --project bench --compare bench/baseline.json",
    "bench:build": "vp pack --entry bench/entry.ts --format esm --outDir dist/bench --no-dts",
    "e2e": "vp pack && vp build && vp exec playwright test",
    "check": "vp check",
    "format": "vp check --fix",
    "test": "vp test --fileParallelism"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-jisho",
          "title": "Jisho",
          "icon": "media/jisho.svg"
        }
      ]
    },
    "views": {
      "vscode-jisho": [
        {
          "id": "vscode-jisho.searchView",
          "name": "Dictionary",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-jisho.lookupSelection",
        "title": "Look Up Selection",
        "category": "Jisho"
      },
      {
        "command": "vscode-jisho.speakSelection",
        "title": "Speak Selection",
        "category": "Jisho"
      },
      {
        "command": "vscode-jisho.openSettings",
        "title": "Open Settings",
        "category": "Jisho"
      },
      {
        "command": "vscode-jisho.showStartupTrace",
        "title": "Show Startup Trace",
        "category": "Jisho"
      },
      {
        "command": "vscode-jisho.addSpacing",
        "title": "Add Word Spacing (分かち書き)",
        "category": "Jisho"
      },
      {
        "command": "vscode-jisho.removeSpacing",
        "title": "Remove Word Spacing",
        "category": "Jisho"
      },
      {
        "command": "vscode-jisho.addFurigana",
        "title": "Add Furigana (ふりがな)",
        "category": "Jisho"
      },
      {
        "command": "vscode-jisho.removeFurigana",
        "title": "Remove Furigana",
        "category": "Jisho"
      }
    ],
    "configuration": {
      "title": "Jisho",
      "properties": {
        "vscode-jisho.highlighting.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Color Japanese text by part of speech in Markdown and plain-text files — a syntax highlighter for prose (verbs, nouns, particles, and auxiliaries each get a theme color), making word boundaries visible."
        },
        "vscode-jisho.hover.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a dictionary hover (reading, meanings, conjugation breakdown) over Japanese text in Markdown and plain-text files."
        },
        "vscode-jisho.grammar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Explain grammar in hovers and the conjugation table: what a particle (は, を, に) does, and what an auxiliary (〜たい, 〜てしまう) adds to a conjugated verb. Turn off to keep hovers to dictionary definitions only."
        },
        "vscode-jisho.appearance.textScale": {
          "type": "number",
          "default": 1.08,
          "minimum": 0.8,
          "maximum": 2,
          "description": "Text size in the Jisho panel, as a multiplier over VS Code's font size. Kanji often need a little more room than Latin text."
        },
        "vscode-jisho.strokeOrder.guideStyle": {
          "type": "string",
          "enum": [
            "offset",
            "aligned"
          ],
          "enumDescriptions": [
            "Direction arrows sit beside the stroke, leaving it visible while it draws.",
            "Direction arrows trace the stroke's own path (Duolingo-style)."
          ],
          "default": "offset",
          "description": "How the stroke-order player draws its direction guides."
        }
      }
    },
    "submenus": [
      {
        "id": "vscode-jisho.editorSubmenu",
        "label": "Jisho"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "vscode-jisho.editorSubmenu",
          "group": "1_jisho"
        }
      ],
      "vscode-jisho.editorSubmenu": [
        {
          "command": "vscode-jisho.lookupSelection",
          "group": "1_actions@1"
        },
        {
          "command": "vscode-jisho.speakSelection",
          "group": "1_actions@2"
        },
        {
          "command": "vscode-jisho.addSpacing",
          "group": "2_spacing@1"
        },
        {
          "command": "vscode-jisho.removeSpacing",
          "group": "2_spacing@2"
        },
        {
          "command": "vscode-jisho.addFurigana",
          "group": "2_spacing@3"
        },
        {
          "command": "vscode-jisho.removeFurigana",
          "group": "2_spacing@4"
        }
      ]
    }
  },
  "activationEvents": [],
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@saeris/configs": "^1.6.1",
    "@scriptin/jmdict-simplified-types": "^3.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@varlock/bumpy": "^1.18.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.2.0",
    "deoptkit": "^0.1.0",
    "jsdom": "^29.1.1",
    "ovsx": "^0.10.0",
    "playwright": "^1.61.1",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wanakana": "^5.3.1"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=22",
    "vscode": "^1.85.0"
  },
  "packageManager": "yarn@4.17.0",
  "bumpy": {
    "buildCommand": "vp pack && vp build && vp exec node scripts/package-platforms.ts",
    "publishCommand": "vp exec node scripts/publish-vsix.ts",
    "skipNpmPublish": true
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tursodatabase/database": "^0.6.1",
    "@xstate/react": "^6.1.0",
    "class-variance-authority": "^0.7.1",
    "lindera-wasm-nodejs-ipadic": "^2.0.0",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.7",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "valibot": "^1.4.2",
    "xstate": "^5.32.3"
  }
}
