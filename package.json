{
  "name": "vscode-jisho",
  "displayName": "Jisho — Japanese Dictionary",
  "version": "0.0.0",
  "description": "An offline Japanese dictionary in your sidebar: vocabulary and kanji search powered by JMdict, Kanjidic, and friends.",
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "japanese",
    "dictionary",
    "jisho",
    "jmdict",
    "kanji"
  ],
  "homepage": "https://github.com/Saeris/vscode-jisho#readme",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saeris/vscode-jisho.git"
  },
  "publisher": "saeris",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "ci": "vp check && vp test",
    "build": "vp pack && vp build && vp exec vsce package --no-yarn",
    "build:platforms": "vp pack && vp build && vp exec node scripts/package-platforms.ts",
    "build:data": "vp exec node scripts/build-data.ts",
    "build:data:full": "vp exec node scripts/build-data.ts --full",
    "check": "vp check",
    "format": "vp check --fix",
    "test": "vp test --fileParallelism"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-jisho",
          "title": "Jisho",
          "icon": "media/jisho.svg"
        }
      ]
    },
    "views": {
      "vscode-jisho": [
        {
          "id": "vscode-jisho.searchView",
          "name": "Dictionary",
          "type": "webview"
        }
      ]
    }
  },
  "activationEvents": [],
  "devDependencies": {
    "@saeris/configs": "^1.6.1",
    "@scriptin/jmdict-simplified-types": "^3.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@varlock/bumpy": "^1.18.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vscode/vsce": "^3.2.0",
    "ovsx": "^0.10.0",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wanakana": "^5.3.1"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=22",
    "vscode": "^1.85.0"
  },
  "packageManager": "yarn@4.17.0",
  "bumpy": {
    "buildCommand": "vp pack && vp build && vp exec node scripts/package-platforms.ts",
    "publishCommand": "vp exec node scripts/publish-vsix.ts",
    "skipNpmPublish": true
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tursodatabase/database": "^0.6.1",
    "@xstate/react": "^6.1.0",
    "class-variance-authority": "^0.7.1",
    "lindera-wasm-nodejs-ipadic": "^2.0.0",
    "react": "^19.2.7",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "valibot": "^1.4.2",
    "xstate": "^5.32.3"
  }
}
